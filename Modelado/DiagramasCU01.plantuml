@startuml RealizaciónCu1VistaDinámica
skinparam roundcorner 20
skinparam maxmessagesize 60
autonumber

Actor ":__Usuario__" as U
create boundary "__:PantallaRegistrarTarea__" as PRT
U --> PRT : opcionCrearNuevaTarea()
PRT -> PRT : abrirVentana()
create control "__:GestorRegistrarTarea__" as GRT
PRT --> GRT : newRegistrarTarea()
GRT -> PRT : solicitarIngresoDatos()
U -> PRT : tomarIngresoNombre()
U -> PRT : tomarIngresoDescripcion()
PRT  -> GRT : tomarIngresoDatos()
GRT -> GRT : buscarPrioridades()
entity "__:Prioridad__" as PR #LightCoral
loop Tomar nombres de prioridades
else Mientras existan prioridades
    GRT -> PR : getNombre()
end
GRT -> GRT: buscarUsuariosProyecto()
entity "__:Proyectos__" as P #LightCoral
loop Verificar nombres de Proyectos
else Mientras existan proyectos
    GRT -> P: esTuNombre()
end

entity "__Selec:Proyecto__" as SP
loop Tomar nombres de usuario
else Mientras existan roles en proyecto
GRT->SP: getUsuariosEnProyecto()
entity "__RolProyecto__" as RP
loop Tomar nombre de usuarios
else mientras haya nombres de usuario
SP -> RP: getNombreUsuarios()
entity "__Usuario__" as US
RP -> US: getNombre()
end
end

GRT -> PRT : mostrarDatosParaSeleccion()
U -> PRT : tomarSeleccionFechaHoraFin()
U -> PRT: tomarSeleccionUsuarioAsignado()
U -> PRT : tomarSeleccionPrioridad()
PRT -> GRT : tomarSeleccionDatos()
GRT -> GRT : buscarUsuarioLogueado()
entity "__Activa:Sesión__" as ASS
GRT -> ASS : getUsuarioLogueado()

GRT -> GRT : verificarDatosMinimos()
GRT -> GRT : getFechaHoraActual()
GRT -> GRT : buscarEstadoPendiente()
loop Buscar estado Pendiente
    entity "__:EstadoTarea__" as E #LightCoral
else Mientras existan estados
    GRT -> E : sosPendiente()
end

GRT -> GRT : crearTarea()
GRT -> SP : crearTarea()
create entity "__Nueva:Tarea__" as T
SP --> T : registrar()
GRT -> GRT : finCU()

@enduml

@startuml RealizaciónCu1VistaEstática
left to right direction
hide <<Entity>> circle
hide <<Control>> circle
hide <<Boundary>> circle
class Usuario<<Entity>>{
    - email
    - nombreUsuario
    - contraseña
    + 14. getNombre()
}

class Proyecto<<Entity>>{
    - nombre
    - descripcion
    + 11. esTuNombre()
    + 12. getUsuariosProyecto()
}

class Tarea<<Entity>>{
    - nombre
    - descripción
    - fechaInicio
    - fechaFin
    - fechaEntrega
    + 28. registrar()
    + archivar()
    + finalizar()
    + eliminar()
    + revisar()
    + ponerEnPendiente()
    + hacer()
}

class RolProyecto<<Entity>>{
    - nombreUsuario
    + 13.getNombreUsuario()
}
class EstadoTarea<<Entity>>{
    - nombre
    - descripción
    + 25. sosPendiente()
}

class PrioridadTarea<<Entity>>{
    - nombre
    - descripción
    + 9. getNombre()
}

class GestorRegistrarTarea <<Control>> {
    - fechaHoraActual
    - estadoPendiente
    - nombreTarea
    - descripcionTarea
    - fechaHoraFinTarea
    - prioridadTarea
    - nombreProyecto
    + 3. newRegistrarTarea()
    + 7. tomarIngresoDatos()
    + 8. buscarPrioridades()
    + 10. buscarUsuariosProyectos()
    + 19. tomarSeleccionDatos()
    + 20. buscarUsuarioLogueado()
    + 22. verificarDatosMinimos()
    + 23. getFechaHoraActual()
    + 24. buscarEstadoPendiente()
    + 26. crearTarea()
    + 30. finCU()
}

class PantallaRegistrarTarea <<Boundary>> {
    - opcCancelar
    - opcAceptar
    - inputNombre
    - inputDescripcion
    + 1. opcionCrearNuevaTarea()
    + 2. abrirVentana()
    + 4. solicitarIngresoDatos()
    + 5. tomarIngresoNombre()
    + 6. tomarIngresoDescripcion()
    + 15. mostrarDatosParaSeleccion()
    + 16. tomarSelecciónFechaHoraFin()
    + 17. tomarSelecciónUsuarioAsignado()
    + 18. tomarSelecciónPrioridad()
}

class Sesión<<Entity>>{
    - fechaHoraInicio
    - fechaHoraFin
    + 21. getUsuarioLogueado()
}

PantallaRegistrarTarea ..> GestorRegistrarTarea
PantallaRegistrarTarea <.. GestorRegistrarTarea
GestorRegistrarTarea ..> PrioridadTarea
GestorRegistrarTarea ..> Sesión
GestorRegistrarTarea ..> EstadoTarea
GestorRegistrarTarea ..> Proyecto
Sesión --> "1" Usuario : usuario
Proyecto --> "1..*" Tarea : tareas
Proyecto -->"0..*" RolProyecto: rolProyecto
RolProyecto -->"1" Usuario: usuario

@enduml