{
  "name": "microservice-tasks-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "implicitDependencies": ["microservice-tasks"],
  "targets": {
    "e2e": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{e2eProjectRoot}"],
      "options": {
        "jestConfig": "apps/microservice-tasks-e2e/jest.config.cts",
        "passWithNoTests": true
      },
      "dependsOn": ["microservice-tasks:build", "microservice-tasks:serve"]
    }
  }
}
